# Copy to autotune.env (same directory) and adjust. Do not commit autotune.env (secrets).
#
# optional webhook (also works if exported in shell before start_autotune.sh):
# NOTIFY_WEBHOOK_URL=https://...
#
export PLATEAI_HOME=/opt/vscc/plateai

# Benchmark & loop
export BENCH_MODE=full
export BENCH_TIMEOUT=120
export PLATEAU_ROUNDS=5
export MIN_GAIN=0.001
export MAX_ROUNDS=14

# Docker image for train step
export PLATEAI_IMAGE=ghcr.io/vesaaa/plateai:v1.0.3-cpu

# Large positive pool (from tools/sample_training_pool.py); unset uses $DATA/2000原图.csv in iter script
export POOL_CSV=/opt/vscc/plateai/data/pool_sampled_50k.csv
export MIX_MAX_ROWS=25000
export TRAIN_MAX_ROWS=20000

# Paths (usually defaults are fine)
export DATA=/opt/vscc/plateai/data
export OUT=/opt/vscc/plateai/output
export CKPT=/opt/vscc/plateai/checkpoints
export CACHE=/opt/vscc/plateai/cache
export BACK=/opt/vscc/plateai/backups
export TOOLS=/opt/vscc/plateai/tools
export PLATEX_MODELS=/opt/vscc/platex/models

# Verify after each train (default 0 = run verify + rollback on regression)
# export SKIP_VERIFY=1
